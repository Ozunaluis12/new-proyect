{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: pub get",
      "type": "shell",
      "command": "flutter pub get",
      "options": {
        "cwd": "${workspaceFolder}/Loginova"
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter: Run",
      "type": "shell",
      "command": "flutter run",
      "options": {
        "cwd": "${workspaceFolder}/Loginova"
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter: Build APK",
      "type": "shell",
      "command": "flutter build apk",
      "options": {
        "cwd": "${workspaceFolder}/Loginova"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: dotnet restore",
      "type": "shell",
      "command": "dotnet restore",
      "options": {
        "cwd": "${workspaceFolder}/LoginovaBackend/LoginovaAPI"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Run",
      "type": "shell",
      "command": "dotnet run",
      "options": {
        "cwd": "${workspaceFolder}/LoginovaBackend/LoginovaAPI"
      },
      "problemMatcher": []
    },
    {
      "label": "Scripts: Start Backend",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/start-backend.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Scripts: Build APK",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build-apk.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Scripts: Run Local",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-local.ps1"
      ],
      "problemMatcher": []
    }
  ]
}
